# === สำหรับผู้ดูแลระบบเท่านั้น (ตั้งครั้งเดียวตอนแจกโปรแกรม) ===
# ผู้ใช้ทั่วไปไม่ต้องแก้ไฟล์นี้ — ใช้ปุ่ม「ส่งไปโปรแกรม」บนเว็บแทน

CONNECTOR_PORT=8780
CONNECTOR_PUBLIC_URL=http://127.0.0.1:8780
WEB_PUBLIC_URL=http://localhost:5173
SUPABASE_URL=
# คีย์สาธารณะจาก Supabase → Settings → API (anon หรือ publishable)
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
# ทางเลือก — ผู้ดูแลเท่านั้น อย่าแจกให้ผู้ใช้
SUPABASE_SERVICE_ROLE_KEY=
# ทางเลือก: ตั้ง room คงที่ (ไม่จำเป็นถ้าใช้ user-config.json จากเว็บ)
DEFAULT_ROOM_ID=
# Google Cloud Text-to-Speech API key (optional — or save in dashboard Voice page)
GOOGLE_TTS_API_KEY=
# Path-style user data (Windows: %APPDATA%/TheSteamerZone) — auto if empty
USER_DATA_DIR=
