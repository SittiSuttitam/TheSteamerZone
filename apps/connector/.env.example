# === สำหรับผู้ดูแลระบบเท่านั้น (ตั้งครั้งเดียวตอนแจกโปรแกรม) ===
# ผู้ใช้ทั่วไปไม่ต้องแก้ไฟล์นี้ — ใช้ปุ่ม「ส่งไปโปรแกรม」บนเว็บแทน

CONNECTOR_PORT=8780
CONNECTOR_PUBLIC_URL=http://127.0.0.1:8780
WEB_PUBLIC_URL=https://thesteamerzone.vercel.app
SUPABASE_URL=https://YOUR_REF.supabase.co
# === จำเป็นสำหรับ build โปรแกรม Connector (pair ห้อง) ===
# Supabase Dashboard → Settings → API Keys → Secret key (sb_secret_…)
SUPABASE_SECRET_KEY=
# legacy (ใช้แทน SECRET ได้): service_role JWT (eyJ…)
SUPABASE_SERVICE_ROLE_KEY=
# สำหรับซิงก์หลังล็อกอินเว็บ (localhost) — อย่างใดอย่างหนึ่ง
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
# ทางเลือก: ตั้ง room คงที่ (ไม่จำเป็นถ้าใช้ user-config.json จากเว็บ)
DEFAULT_ROOM_ID=
# Google Cloud Text-to-Speech API key (optional — or save in dashboard Voice page)
GOOGLE_TTS_API_KEY=
# Path-style user data (Windows: %APPDATA%/TheSteamerZone) — auto if empty
USER_DATA_DIR=
